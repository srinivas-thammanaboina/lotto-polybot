# Poly-Latency-Bot Configuration
# Copy to .env and fill in values. All fields have safe defaults.

# --- Mode ---
# Options: dry_run, simulation, paper, live (default: simulation)
BOT_MODE=simulation

# --- Deployment ---
REGION_TAG=local

# --- Polymarket credentials (required for paper/live) ---
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=

# --- Polymarket endpoints ---
# POLYMARKET_MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
# POLYMARKET_USER_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user
# POLYMARKET_RTDS_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/rtds
# POLYMARKET_REST_URL=https://clob.polymarket.com
# DISCOVERY_REFRESH_SECS=30

# --- Binance (primary CEX feed) ---
# BINANCE_WS_URL=wss://stream.binance.com:9443
# BINANCE_RECONNECT_BACKOFF_MS=1000
# BINANCE_MAX_RECONNECT=10
# BINANCE_STALE_MS=3000

# --- Coinbase (backup, disabled by default) ---
# COINBASE_ENABLED=false
# COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com
# COINBASE_RECONNECT_BACKOFF_MS=1000
# COINBASE_STALE_MS=5000

# --- Strategy: 5-minute markets ---
# STRATEGY_5M_MIN_NET_EDGE=0.02
# STRATEGY_5M_MIN_CONFIDENCE=0.60
# STRATEGY_5M_MIN_DEPTH_USDC=100
# STRATEGY_5M_MAX_HOLD_SECS=240
# STRATEGY_5M_STALE_FEED_MS=2000
# STRATEGY_5M_STALE_BOOK_MS=3000
# STRATEGY_5M_COOLDOWN_SECS=10

# --- Strategy: 15-minute markets ---
# STRATEGY_15M_MIN_NET_EDGE=0.015
# STRATEGY_15M_MIN_CONFIDENCE=0.55
# STRATEGY_15M_MIN_DEPTH_USDC=100
# STRATEGY_15M_MAX_HOLD_SECS=780
# STRATEGY_15M_STALE_FEED_MS=3000
# STRATEGY_15M_STALE_BOOK_MS=5000
# STRATEGY_15M_COOLDOWN_SECS=15

# --- Strategy: latency ---
# STRATEGY_LATENCY_DECAY_MS=200

# --- Risk ---
# RISK_MAX_POS_PER_MARKET=50
# RISK_MAX_CONCURRENT_POS=4
# RISK_MAX_GROSS_EXPOSURE=200
# RISK_MAX_DAILY_DD=50
# RISK_MAX_TOTAL_DD=100
# RISK_MAX_CONSEC_LOSSES=5
# RISK_MAX_NOTIONAL_ORDER=25

# --- Execution ---
# EXEC_MAX_RETRIES=2
# EXEC_RETRY_BACKOFF_MS=500
# EXEC_STALE_SIGNAL_MS=1000
# EXEC_MAX_CONCURRENT_ORDERS=2

# --- Telemetry ---
RUST_LOG=info
# LOG_JSON=false
# EVENT_LOG_PATH=data/events.jsonl
